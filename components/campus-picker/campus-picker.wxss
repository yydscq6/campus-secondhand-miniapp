.campus-picker {
  display: flex; align-items: center;
  height: 96rpx; background: #f8f9fa;
  border-radius: 20rpx; padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}
.campus-picker.has-value { border-color: rgba(108,92,231,0.2); background: rgba(108,92,231,0.04); }
.cp-emoji { font-size: 32rpx; margin-right: 16rpx; }
.cp-text { flex: 1; font-size: 28rpx; color: var(--text-hint); }
.campus-picker.has-value .cp-text { color: var(--text-primary); font-weight: 500; }
.cp-arrow { font-size: 32rpx; color: var(--text-hint); }
