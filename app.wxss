/* ===== 全局设计系统 ===== */
page {
  --primary: #6C5CE7;
  --primary-light: #a29bfe;
  --primary-dark: #5641d4;
  --accent: #fd79a8;
  --success: #00b894;
  --warning: #fdcb6e;
  --danger: #e17055;
  --bg: #f0f2f5;
  --card: #ffffff;
  --text-primary: #2d3436;
  --text-secondary: #636e72;
  --text-hint: #b2bec3;
  --border: #eef0f3;
  --shadow: 0 4rpx 24rpx rgba(108,92,231,0.08);
  --shadow-lg: 0 12rpx 40rpx rgba(108,92,231,0.15);
  --radius: 24rpx;
  --radius-sm: 16rpx;
  --radius-lg: 32rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', Arial, sans-serif;
  background: var(--bg);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
}

/* ===== 工具类 ===== */
.container { padding: 0 32rpx; }
.card {
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

.text-primary { color: var(--primary); }
.text-accent { color: var(--accent); }
.text-success { color: var(--success); }
.text-secondary { color: var(--text-secondary); }
.text-hint { color: var(--text-hint); }
.text-bold { font-weight: 600; }
.text-center { text-align: center; }

.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis-2 { overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }

/* ===== 按钮系统 ===== */
.btn {
  display: inline-flex; align-items: center; justify-content: center;
  border-radius: 48rpx; font-size: 28rpx; font-weight: 600;
  padding: 0 48rpx; height: 88rpx; border: none;
  transition: all 0.3s ease;
}
.btn::after { border: none; }
.btn-primary {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #fff; box-shadow: 0 8rpx 24rpx rgba(108,92,231,0.35);
}
.btn-primary:active { transform: scale(0.96); box-shadow: 0 4rpx 12rpx rgba(108,92,231,0.25); }
.btn-outline {
  background: transparent; color: var(--primary);
  border: 2rpx solid var(--primary); border-radius: 48rpx;
}
.btn-accent {
  background: linear-gradient(135deg, #fd79a8 0%, #e84393 100%);
  color: #fff; box-shadow: 0 8rpx 24rpx rgba(253,121,168,0.35);
}
.btn-sm { height: 64rpx; font-size: 24rpx; padding: 0 32rpx; }
.btn-block { display: flex; width: 100%; }
.btn-ghost { background: rgba(108,92,231,0.08); color: var(--primary); }

/* ===== 标签系统 ===== */
.tag {
  display: inline-flex; align-items: center;
  padding: 4rpx 16rpx; border-radius: 20rpx; font-size: 20rpx; font-weight: 500;
}
.tag-primary { background: rgba(108,92,231,0.1); color: var(--primary); }
.tag-accent { background: rgba(253,121,168,0.1); color: var(--accent); }
.tag-success { background: rgba(0,184,148,0.1); color: var(--success); }
.tag-warning { background: rgba(253,203,110,0.15); color: #e17055; }
.tag-gray { background: #f0f2f5; color: var(--text-secondary); }

/* ===== 分割线 ===== */
.divider { height: 1rpx; background: var(--border); margin: 24rpx 0; }

/* ===== 动画 ===== */
@keyframes fadeIn { from { opacity: 0; transform: translateY(20rpx); } to { opacity: 1; transform: translateY(0); } }
@keyframes slideUp { from { opacity: 0; transform: translateY(60rpx); } to { opacity: 1; transform: translateY(0); } }
@keyframes pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.05); } }
.anim-fade { animation: fadeIn 0.4s ease-out both; }
.anim-slide { animation: slideUp 0.5s ease-out both; }

/* ===== 空状态 ===== */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 60rpx; color: var(--text-hint);
}
.empty-state .empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-state .empty-text { font-size: 28rpx; }

/* ===== 安全区域 ===== */
.safe-bottom { padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx); }
