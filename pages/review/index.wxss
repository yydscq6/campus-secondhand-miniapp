.page-review{min-height:100vh;background:var(--bg)}.write-header{padding:32rpx}.write-title{font-size:34rpx;font-weight:700}.write-form{padding:0 32rpx 40rpx}.rating-section{text-align:center;margin-bottom:40rpx}.rating-label{font-size:28rpx;font-weight:600;display:block;margin-bottom:20rpx}.rating-stars{display:flex;justify-content:center;gap:16rpx;margin-bottom:12rpx}.star{font-size:48rpx;opacity:0.3;transition:all 0.2s}.star.active{opacity:1;transform:scale(1.1)}.rating-text{font-size:26rpx;color:var(--primary);font-weight:600}.content-section{margin-bottom:40rpx}.content-label{font-size:28rpx;font-weight:600;display:block;margin-bottom:16rpx}.content-textarea{width:100%;height:240rpx;background:#fff;border-radius:20rpx;padding:24rpx;font-size:28rpx;border:2rpx solid var(--border);box-sizing:border-box}.review-header{display:flex;justify-content:space-between;align-items:center;padding:32rpx 0}.review-title{font-size:34rpx;font-weight:700}.review-count{font-size:24rpx;color:var(--text-hint)}.review-list{display:flex;flex-direction:column;gap:16rpx;padding-bottom:40rpx}.review-item{border-radius:var(--radius);padding:24rpx}.ri-header{display:flex;align-items:center;margin-bottom:16rpx}.ri-avatar{width:60rpx;height:60rpx;background:linear-gradient(135deg,#74b9ff,#0984e3);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:26rpx;font-weight:600;margin-right:16rpx}.ri-user{flex:1}.ri-name{font-size:26rpx;font-weight:600;display:block}.ri-time{font-size:20rpx;color:var(--text-hint);display:block}.ri-stars{font-size:22rpx}.ri-content{font-size:26rpx;color:var(--text-secondary);line-height:1.8}.disabled{opacity:0.6}