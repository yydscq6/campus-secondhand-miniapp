.page-orders{min-height:100vh;background:var(--bg)}.order-tabs{display:flex;background:#fff;padding:0 32rpx;border-bottom:1rpx solid var(--border)}.tab-item{flex:1;text-align:center;padding:28rpx 0;font-size:28rpx;color:var(--text-secondary);position:relative;transition:all 0.3s}.tab-item.active{color:var(--primary);font-weight:600}.tab-item.active::after{content:"";position:absolute;bottom:0;left:25%;right:25%;height:4rpx;background:var(--primary);border-radius:2rpx}.order-list{display:flex;flex-direction:column;gap:20rpx;padding:24rpx 32rpx}.order-card{border-radius:var(--radius);overflow:hidden;padding:24rpx}.order-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20rpx;padding-bottom:16rpx;border-bottom:1rpx solid var(--border)}.order-no{font-size:22rpx;color:var(--text-hint)}.order-status{font-size:24rpx;font-weight:600}.status-0{color:#e17055}.status-1{color:#00b894}.status-2{color:var(--text-hint)}.status-3{color:#fd79a8}.order-body{display:flex;gap:20rpx}.order-img{width:160rpx;height:160rpx;border-radius:var(--radius-sm);flex-shrink:0;display:block}.order-info{flex:1;display:flex;flex-direction:column;justify-content:space-between}.order-name{font-size:28rpx;font-weight:600;display:block}.order-seller{font-size:22rpx;color:var(--text-hint)}.order-price{font-size:32rpx;font-weight:800;color:#e17055}.order-actions{display:flex;justify-content:flex-end;gap:16rpx;margin-top:20rpx;padding-top:16rpx;border-top:1rpx solid var(--border)}