.page-chat{display:flex;flex-direction:column;height:100vh;background:var(--bg)}.chat-messages{flex:1;overflow-y:auto;padding:24rpx;display:flex;flex-direction:column;gap:24rpx}.msg-row{display:flex;align-items:flex-start;gap:16rpx}.msg-self{flex-direction:row-reverse}.msg-avatar{width:72rpx;height:72rpx;border-radius:50%;background:linear-gradient(135deg,#a29bfe,#6C5CE7);display:flex;align-items:center;justify-content:center;font-size:28rpx;color:#fff;font-weight:600;flex-shrink:0}.self-avatar{background:linear-gradient(135deg,#74b9ff,#0984e3)}.msg-bubble{max-width:70%;padding:20rpx 28rpx;border-radius:24rpx;position:relative}.msg-bubble.other{background:#fff;border-radius:4rpx 24rpx 24rpx 24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,0.04)}.msg-bubble.self{background:linear-gradient(135deg,#6C5CE7,#a29bfe);border-radius:24rpx 4rpx 24rpx 24rpx}.msg-text{font-size:28rpx;line-height:1.6;display:block}.msg-bubble.other .msg-text{color:var(--text-primary)}.msg-bubble.self .msg-text{color:#fff}.msg-time{font-size:20rpx;color:var(--text-hint);display:block;margin-top:8rpx}.msg-bubble.self .msg-time{color:rgba(255,255,255,0.7)}.chat-input-bar{display:flex;align-items:center;gap:16rpx;padding:16rpx 24rpx;background:#fff;border-top:1rpx solid var(--border)}.chat-input{flex:1;height:72rpx;background:var(--bg);border-radius:36rpx;padding:0 28rpx;font-size:28rpx}.send-btn{padding:16rpx 32rpx;border-radius:36rpx;font-size:28rpx;font-weight:600;background:var(--bg);color:var(--text-hint);transition:all 0.3s}.send-btn.active{background:var(--primary);color:#fff}