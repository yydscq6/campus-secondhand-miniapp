<view class="page-mine">
  <view class="mine-header" style="padding-top:{{statusBarHeight}}px">
    <view class="header-bg"></view>
    <view class="user-section">
      <view class="avatar-wrap" bindtap="goLogin">
        <view class="avatar">{{isLoggedIn ? userInfo.nickname[0] : "?"}}</view>
        <view class="avatar-badge" wx:if="{{isLoggedIn}}">✓</view>
      </view>
      <view class="user-info" bindtap="goLogin">
        <text class="user-name">{{isLoggedIn ? userInfo.nickname : "点击登录"}}</text>
        <text class="user-desc">{{isLoggedIn ? (userInfo.phone || "校园认证用户") : "登录享受更多服务"}}</text>
      </view>
      <view class="header-arrow" wx:if="{{isLoggedIn}}">›</view>
    </view>
    <view class="stats-row">
      <view class="stat-item"><text class="stat-num">{{stats.publish}}</text><text class="stat-label">发布</text></view>
      <view class="stat-divider"></view>
      <view class="stat-item"><text class="stat-num">{{stats.sold}}</text><text class="stat-label">已售</text></view>
      <view class="stat-divider"></view>
      <view class="stat-item"><text class="stat-num">{{stats.bought}}</text><text class="stat-label">已购</text></view>
      <view class="stat-divider"></view>
      <view class="stat-item"><text class="stat-num">{{stats.favorite}}</text><text class="stat-label">收藏</text></view>
    </view>
  </view>
  <view class="menu-section container">
    <view class="menu-card card">
      <view class="menu-item" bindtap="goPage" data-url="/pages/my-products/index"><view class="menu-left"><image class="menu-icon" src="/images/icons/package.svg" /><view class="menu-text"><text class="menu-title">我的发布</text><text class="menu-desc">管理发布的商品</text></view></view><text class="menu-arrow">›</text></view>
      <view class="menu-item" bindtap="goPage" data-url="/pages/orders/index"><view class="menu-left"><image class="menu-icon" src="/images/icons/clipboard.svg" /><view class="menu-text"><text class="menu-title">我的订单</text><text class="menu-desc">查看交易订单</text></view></view><text class="menu-arrow">›</text></view>
      <view class="menu-item" bindtap="goPage" data-url="/pages/favorites/index"><view class="menu-left"><image class="menu-icon" src="/images/icons/heart.svg" /><view class="menu-text"><text class="menu-title">我的收藏</text><text class="menu-desc">收藏的宝贝</text></view></view><text class="menu-arrow">›</text></view>
      <view class="menu-item" bindtap="goPage" data-url="/pages/messages/index"><view class="menu-left"><image class="menu-icon" src="/images/icons/message.svg" /><view class="menu-text"><text class="menu-title">消息中心</text><text class="menu-desc">交易和系统通知</text></view></view><view class="menu-right"><view class="menu-badge">3</view><text class="menu-arrow">›</text></view></view>
      <view class="menu-item" bindtap="goPage" data-url="/pages/review/index"><view class="menu-left"><image class="menu-icon" src="/images/icons/star.svg" /><view class="menu-text"><text class="menu-title">我的评价</text><text class="menu-desc">查看收到的评价</text></view></view><text class="menu-arrow">›</text></view>
      <view class="menu-item" bindtap="goPage" data-url=""><view class="menu-left"><image class="menu-icon" src="/images/icons/shield.svg" /><view class="menu-text"><text class="menu-title">交易保障</text><text class="menu-desc">了解平台保障政策</text></view></view><text class="menu-arrow">›</text></view>
      <view class="menu-item" bindtap="goPage" data-url=""><view class="menu-left"><image class="menu-icon" src="/images/icons/settings.svg" /><view class="menu-text"><text class="menu-title">设置</text><text class="menu-desc">账号与安全</text></view></view><text class="menu-arrow">›</text></view>
    </view>
  </view>
  <view class="logout-section container" wx:if="{{isLoggedIn}}"><view class="btn btn-outline btn-block" bindtap="logout">退出登录</view></view>
  <view class="footer-version">校易淘 v1.0.0</view>
</view>