.page-fav{min-height:100vh;background:var(--bg)}.fav-header{display:flex;justify-content:space-between;align-items:center;padding:32rpx}.fav-title{font-size:34rpx;font-weight:700}.fav-count{font-size:24rpx;color:var(--text-hint)}.fav-list{display:flex;flex-direction:column;gap:20rpx;padding:0 32rpx 40rpx}.fav-card{display:flex;border-radius:var(--radius);overflow:hidden;animation:fadeIn 0.4s ease-out both}.fav-card:active{transform:scale(0.98)}.fav-img{width:200rpx;height:200rpx;flex-shrink:0;display:block}.fav-body{flex:1;padding:24rpx;display:flex;flex-direction:column;justify-content:space-between}.fav-name{font-size:28rpx;font-weight:600;display:block}.fav-desc{font-size:22rpx;color:var(--text-hint);display:block}.fav-bottom{display:flex;justify-content:space-between;align-items:center;margin-top:12rpx}.fav-price{font-size:32rpx;font-weight:800;color:#e17055}.fav-remove{font-size:22rpx;color:var(--accent);padding:8rpx 20rpx;border:1rpx solid var(--accent);border-radius:20rpx}