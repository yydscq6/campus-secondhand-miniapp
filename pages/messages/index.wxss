.page-msg{min-height:100vh;background:var(--bg)}.msg-header{display:flex;justify-content:space-between;align-items:center;padding:32rpx}.msg-title{font-size:34rpx;font-weight:700}.msg-unread{font-size:22rpx;color:var(--accent);background:rgba(253,121,168,0.1);padding:6rpx 16rpx;border-radius:16rpx}.msg-list{display:flex;flex-direction:column;gap:16rpx;padding:0 32rpx 40rpx}.msg-item{display:flex;gap:20rpx;background:#fff;border-radius:var(--radius);padding:24rpx;transition:all 0.2s}.msg-item:active{transform:scale(0.98)}.msg-item.unread{background:rgba(108,92,231,0.04);border-left:4rpx solid var(--primary)}.msg-icon{position:relative;font-size:40rpx;width:64rpx;height:64rpx;background:var(--bg);border-radius:16rpx;display:flex;align-items:center;justify-content:center;flex-shrink:0}.unread-dot{position:absolute;top:-4rpx;right:-4rpx;width:16rpx;height:16rpx;background:#ff6b6b;border-radius:50%;border:2rpx solid #fff}.msg-body{flex:1;min-width:0}.msg-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8rpx}.msg-name{font-size:28rpx;font-weight:600;color:var(--text-primary)}.msg-time{font-size:22rpx;color:var(--text-hint);flex-shrink:0}.msg-content{font-size:24rpx;color:var(--text-secondary);line-height:1.6;display:block}