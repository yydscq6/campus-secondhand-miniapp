.page-login{min-height:100vh;background:var(--bg);position:relative;overflow:hidden}.login-bg{position:absolute;top:0;left:0;right:0;height:500rpx;background:linear-gradient(135deg,#6C5CE7 0%,#a29bfe 50%,#74b9ff 100%);border-radius:0 0 80rpx 80rpx}.login-top{padding:0 32rpx;position:relative;z-index:2}.back-btn{width:60rpx;height:60rpx;display:flex;align-items:center;justify-content:center;font-size:36rpx;color:#fff;background:rgba(255,255,255,0.2);border-radius:50%}.login-content{position:relative;z-index:2;padding:40rpx 40rpx}.login-logo{display:flex;flex-direction:column;align-items:center;margin-bottom:48rpx}.logo-circle{width:120rpx;height:120rpx;background:rgba(255,255,255,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:56rpx;border:4rpx solid rgba(255,255,255,0.4);margin-bottom:16rpx}.logo-title{font-size:44rpx;font-weight:800;color:#fff}.logo-sub{font-size:26rpx;color:rgba(255,255,255,0.8)}.login-form{border-radius:32rpx;padding:40rpx;box-shadow:0 16rpx 48rpx rgba(0,0,0,0.1)}.form-tabs{display:flex;margin-bottom:36rpx;background:var(--bg);border-radius:16rpx;padding:6rpx}.form-tab{flex:1;text-align:center;padding:16rpx 0;font-size:28rpx;border-radius:12rpx;color:var(--text-secondary);transition:all 0.3s}.form-tab.active{background:#fff;color:var(--primary);font-weight:600;box-shadow:0 2rpx 8rpx rgba(0,0,0,0.08)}.input-group{display:flex;flex-direction:column;gap:24rpx;margin-bottom:36rpx}.input-item{display:flex;align-items:center;height:96rpx;background:var(--bg);border-radius:20rpx;padding:0 24rpx;border:2rpx solid transparent;transition:border-color 0.3s}.input-item:focus-within{border-color:var(--primary)}.input-icon{font-size:32rpx;margin-right:16rpx}.input-field{flex:1;font-size:28rpx;height:96rpx}.pwd-toggle{font-size:28rpx;padding:12rpx}.login-btn{margin-top:8rpx;height:96rpx;font-size:32rpx;border-radius:20rpx}.login-hint{text-align:center;margin-top:24rpx}.hint-text{font-size:22rpx;color:var(--text-hint)}.disabled{opacity:0.6}
.input-icon{width:32rpx;height:32rpx;margin-right:16rpx}