.page-publish { min-height: 100vh; background: var(--bg); padding-bottom: 160rpx; }
.pub-header { padding: 40rpx 32rpx 24rpx; background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%); border-radius: 0 0 48rpx 48rpx; }
.pub-title { font-size: 40rpx; font-weight: 800; color: #fff; display: block; }
.pub-subtitle { font-size: 26rpx; color: rgba(255,255,255,0.8); display: block; margin-top: 8rpx; }
.pub-form { padding: 32rpx; }
.form-section { margin-bottom: 32rpx; }
.form-label { font-size: 26rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 16rpx; display: block; }
.form-input { height: 88rpx; background: #fff; border-radius: 20rpx; padding: 0 28rpx; font-size: 28rpx; border: 2rpx solid var(--border); }
.form-picker { height: 88rpx; background: #fff; border-radius: 20rpx; padding: 0 28rpx; font-size: 28rpx; border: 2rpx solid var(--border); display: flex; align-items: center; justify-content: space-between; }
.picker-arrow { font-size: 32rpx; color: var(--text-hint); }
.form-row { display: flex; gap: 20rpx; }
.price-input-wrap { display: flex; align-items: center; height: 88rpx; background: #fff; border-radius: 20rpx; padding: 0 28rpx; border: 2rpx solid var(--border); }
.price-sign { font-size: 32rpx; font-weight: 700; color: #e17055; margin-right: 8rpx; }
.price-input { flex: 1; height: 88rpx; }
.condition-tags { display: flex; gap: 16rpx; flex-wrap: wrap; }
.cond-tag { padding: 16rpx 32rpx; border-radius: 40rpx; font-size: 26rpx; background: #fff; color: var(--text-secondary); border: 2rpx solid var(--border); transition: all 0.3s; }
.cond-tag.active { background: var(--primary); color: #fff; border-color: var(--primary); box-shadow: 0 4rpx 16rpx rgba(108,92,231,0.3); }
.form-textarea { width: 100%; height: 200rpx; background: #fff; border-radius: 20rpx; padding: 24rpx; font-size: 28rpx; border: 2rpx solid var(--border); box-sizing: border-box; }
.textarea-count { display: block; text-align: right; font-size: 22rpx; color: var(--text-hint); margin-top: 8rpx; }
.image-grid { display: flex; gap: 20rpx; flex-wrap: wrap; }
.image-item { position: relative; width: 200rpx; height: 200rpx; border-radius: 20rpx; overflow: hidden; }
.preview-img { width: 100%; height: 100%; }
.img-remove { position: absolute; top: 8rpx; right: 8rpx; width: 40rpx; height: 40rpx; background: rgba(0,0,0,0.6); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20rpx; }
.image-add { width: 200rpx; height: 200rpx; border-radius: 20rpx; border: 3rpx dashed var(--border); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx; }
.add-icon { font-size: 48rpx; color: var(--text-hint); }
.add-text { font-size: 22rpx; color: var(--text-hint); }
.pub-bottom { position: fixed; bottom: 0; left: 0; right: 0; padding: 20rpx 32rpx; background: rgba(255,255,255,0.95); backdrop-filter: blur(20px); border-top: 1rpx solid var(--border); }
.disabled { opacity: 0.6; }
.form-hint { display: block; font-size: 22rpx; color: var(--text-hint); margin-top: 10rpx; }
.campus-optional { font-size: 22rpx; color: var(--success); font-weight: 400; }