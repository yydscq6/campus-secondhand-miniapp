<view class="page-publish">
  <view class="pub-header container">
    <text class="pub-title">发布闲置好物</text>
    <text class="pub-subtitle">让你的闲置物品找到新主人</text>
  </view>
  <view class="pub-form container">
    <view class="form-section">
      <text class="form-label">商品图片</text>
      <view class="image-grid">
        <view class="image-item" wx:for="{{images}}" wx:key="*this">
          <image src="{{item}}" mode="aspectFill" class="preview-img"/>
          <view class="img-remove" bindtap="removeImage" data-idx="{{index}}">✕</view>
        </view>
        <view class="image-add" bindtap="chooseImage" wx:if="{{images.length < 3}}">
          <text class="add-icon">+</text>
          <text class="add-text">添加图片</text>
        </view>
      </view>
    </view>
    <view class="form-section">
      <text class="form-label">商品名称</text>
      <input class="form-input" placeholder="请输入商品名称" value="{{form.name}}" bindinput="onInput" data-field="name" />
    </view>
    <view class="form-section">
      <text class="form-label">商品分类</text>
      <picker range="{{categories}}" range-key="name" bindchange="onCategoryChange">
        <view class="form-picker">
          <text wx:if="{{form.category}}">{{form.category}}</text>
          <text wx:else style="color:#b2bec3">请选择分类</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-row">
      <view class="form-section flex-1">
        <text class="form-label">出售价格</text>
        <view class="price-input-wrap">
          <text class="price-sign">¥</text>
          <input class="form-input price-input" type="digit" placeholder="0.00" value="{{form.price}}" bindinput="onInput" data-field="price" />
        </view>
      </view>
      <view class="form-section flex-1">
        <text class="form-label">原价</text>
        <view class="price-input-wrap">
          <text class="price-sign">¥</text>
          <input class="form-input price-input" type="digit" placeholder="0.00" value="{{form.originalPrice}}" bindinput="onInput" data-field="originalPrice" />
        </view>
      </view>
    </view>
    <view class="form-section">
      <text class="form-label">新旧程度</text>
      <view class="condition-tags">
        <view wx:for="{{conditions}}" wx:key="*this" class="cond-tag {{conditionIdx === index ? 'active' : ''}}" bindtap="onConditionChange" data-idx="{{index}}">{{item}}</view>
      </view>
    </view>
    <view class="form-section">
      <text class="form-label">商品描述</text>
      <textarea class="form-textarea" placeholder="请详细描述商品的使用情况、瑕疵等" maxlength="500" value="{{form.description}}" bindinput="onInput" data-field="description" />
      <text class="textarea-count">{{form.description.length}}/500</text>
    </view>
  </view>
  <view class="pub-bottom safe-bottom">
    <button class="btn btn-primary btn-block {{submitting ? 'disabled' : ''}}" bindtap="submit" disabled="{{submitting}}">
      {{submitting ? '发布中...' : '立即发布'}}
    </button>
  </view>
</view>