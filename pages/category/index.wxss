.page-cate { min-height: 100vh; background: var(--bg); padding-bottom: 40rpx; }
.cate-search { padding: 20rpx 32rpx; }
.search-box { display: flex; align-items: center; height: 72rpx; background: #fff; border-radius: 36rpx; padding: 0 28rpx; box-shadow: var(--shadow); }
.search-icon { font-size: 28rpx; margin-right: 16rpx; }
.search-input { flex: 1; font-size: 26rpx; }
.cate-tabs { white-space: nowrap; padding: 16rpx 32rpx; }
.cate-tab { display: inline-block; padding: 12rpx 28rpx; margin-right: 16rpx; border-radius: 32rpx; font-size: 24rpx; background: #fff; color: var(--text-secondary); transition: all 0.3s; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.cate-tab.active { background: var(--primary); color: #fff; box-shadow: 0 4rpx 16rpx rgba(108,92,231,0.3); }
.sort-bar { display: flex; align-items: center; padding: 16rpx 32rpx; gap: 24rpx; }
.sort-item { font-size: 24rpx; color: var(--text-secondary); padding: 8rpx 0; position: relative; }
.sort-item.active { color: var(--primary); font-weight: 600; }
.sort-item.active::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 4rpx; background: var(--primary); border-radius: 2rpx; }
.sort-result { margin-left: auto; font-size: 22rpx; color: var(--text-hint); }
.product-list { display: flex; flex-direction: column; gap: 20rpx; padding: 0 32rpx 40rpx; }
.pro-card { display: flex; padding: 0; border-radius: var(--radius); overflow: hidden; animation: fadeIn 0.4s ease-out both; }
.pro-card:active { transform: scale(0.98); }
.pro-img { width: 240rpx; height: 240rpx; flex-shrink: 0; display: block; }
.pro-body { flex: 1; padding: 24rpx; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
.pro-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); display: block; }
.pro-desc { font-size: 22rpx; color: var(--text-hint); margin-top: 8rpx; display: block; }
.pro-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 16rpx; }
.pro-price { font-size: 34rpx; font-weight: 800; color: #e17055; }
.pro-orig { font-size: 20rpx; color: var(--text-hint); text-decoration: line-through; margin-left: 12rpx; }
.pro-seller-row { display: flex; align-items: center; justify-content: space-between; margin-top: 12rpx; }
.pro-seller { font-size: 20rpx; color: var(--text-hint); }
.pro-views { font-size: 20rpx; color: var(--text-hint); }
.loading-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; color: var(--text-hint); gap: 16rpx; }
.loading-spinner { width: 48rpx; height: 48rpx; border: 4rpx solid #e0e0e0; border-top-color: var(--primary); border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
