.page-mypro{min-height:100vh;background:var(--bg)}.mypro-header{padding:32rpx}.mypro-title{font-size:34rpx;font-weight:700;display:block;margin-bottom:20rpx}.mypro-tabs{display:flex;gap:16rpx}.mypro-tab{padding:12rpx 32rpx;border-radius:32rpx;font-size:26rpx;background:#fff;color:var(--text-secondary);transition:all 0.3s}.mypro-tab.active{background:var(--primary);color:#fff;box-shadow:0 4rpx 16rpx rgba(108,92,231,0.3)}.mypro-list{display:flex;flex-direction:column;gap:20rpx;padding:0 32rpx 40rpx}.mypro-card{display:flex;border-radius:var(--radius);overflow:hidden;padding:0}.mypro-img{width:220rpx;height:220rpx;flex-shrink:0;display:block}.mypro-body{flex:1;padding:24rpx;display:flex;flex-direction:column;justify-content:space-between}.mypro-name{font-size:28rpx;font-weight:600;display:block}.mypro-info{display:flex;align-items:center;justify-content:space-between;margin-top:8rpx}.mypro-price{font-size:32rpx;font-weight:800;color:#e17055}.mypro-meta{font-size:22rpx;color:var(--text-hint);margin-top:8rpx}.mypro-actions{display:flex;gap:16rpx;margin-top:12rpx}.action-btn{padding:8rpx 24rpx;border-radius:20rpx;font-size:22rpx;font-weight:600;transition:all 0.2s}.action-btn.edit{background:rgba(108,92,231,0.1);color:var(--primary)}.action-btn.delete{background:rgba(225,112,85,0.1);color:#e17055}