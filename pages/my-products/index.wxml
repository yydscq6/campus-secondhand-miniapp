<view class="page-mypro">
  <view class="mypro-header container">
    <text class="mypro-title">我的发布</text>
    <view class="mypro-tabs">
      <view class="mypro-tab {{activeTab === 0 ? 'active' : ''}}" bindtap="onTabChange" data-idx="0">出售中</view>
      <view class="mypro-tab {{activeTab === 1 ? 'active' : ''}}" bindtap="onTabChange" data-idx="1">已售出</view>
    </view>
  </view>
  <view class="mypro-list container" wx:if="{{!loading && products.length > 0}}">
    <view class="mypro-card card" wx:for="{{products}}" wx:key="id">
      <image class="mypro-img" src="{{item.imageUrl}}" mode="aspectFill" bindtap="goDetail" data-id="{{item.id}}" />
      <view class="mypro-body">
        <text class="mypro-name ellipsis">{{item.name}}</text>
        <view class="mypro-info">
          <text class="mypro-price">¥{{item.price}}</text>
          <text class="tag tag-{{item.status === 1 ? 'success' : item.status === 0 ? 'warning' : item.status === 4 ? 'accent' : 'gray'}}">{{item.status === 0 ? '待审核' : item.status === 1 ? '已上架' : item.status === 3 ? '已售出' : '审核未通过'}}</text>
        </view>
        <text class="mypro-meta">👁 {{item.viewCount}}次浏览</text>
        <view class="mypro-actions">
          <view class="action-btn edit" bindtap="editProduct" data-id="{{item.id}}">编辑</view>
          <view class="action-btn delete" bindtap="deleteProduct" data-id="{{item.id}}">删除</view>
        </view>
      </view>
    </view>
  </view>
  <view class="empty-state" wx:if="{{!loading && products.length === 0}}">
    <text class="empty-icon">📦</text>
    <text class="empty-text">还没有发布商品</text>
    <view class="btn btn-primary btn-sm" style="margin-top:32rpx" bindtap="">去发布</view>
  </view>
</view>