.page-index { min-height: 100vh; background: #f0f2f5; }

/* ===== 自定义导航栏 ===== */
.nav-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 50%, #74b9ff 100%);
  padding-bottom: 20rpx;
}
.nav-bar__content { display: flex; align-items: center; justify-content: space-between; height: 88rpx; padding: 0 32rpx; }
.nav-logo { display: flex; align-items: center; }
.logo-icon { font-size: 40rpx; margin-right: 12rpx; }
.logo-text { font-size: 36rpx; font-weight: 700; color: #fff; letter-spacing: 2rpx; }
.nav-actions { display: flex; align-items: center; gap: 24rpx; }
.nav-icon-btn { position: relative; width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; }
.nav-icon-btn .iconfont { font-size: 40rpx; filter: grayscale(1) brightness(10); }
.badge { position: absolute; top: -4rpx; right: -4rpx; min-width: 32rpx; height: 32rpx; background: #ff6b6b; color: #fff; font-size: 18rpx; border-radius: 32rpx; display: flex; align-items: center; justify-content: center; padding: 0 8rpx; border: 3rpx solid #fff; }

/* 搜索栏 */
.search-bar { padding: 0 32rpx 12rpx; }
.search-inner {
  display: flex; align-items: center; height: 72rpx;
  background: rgba(255,255,255,0.25); border-radius: 36rpx;
  padding: 0 28rpx; backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255,255,255,0.3);
}
.search-icon { font-size: 28rpx; margin-right: 16rpx; }
.search-input { flex: 1; font-size: 26rpx; color: #fff; height: 72rpx; }
.search-placeholder { color: rgba(255,255,255,0.7); }
.nav-placeholder { background: transparent; }

/* ===== 轮播图 ===== */
.swiper-wrap { padding: 24rpx 32rpx; position: relative; }
.banner-swiper { height: 320rpx; border-radius: 28rpx; overflow: hidden; }
.banner-item {
  height: 100%; border-radius: 28rpx; padding: 40rpx; position: relative; overflow: hidden;
  display: flex; align-items: center;
}
.banner-item-0 { background: linear-gradient(135deg, #6C5CE7, #a29bfe); }
.banner-item-1 { background: linear-gradient(135deg, #00b894, #55efc4); }
.banner-item-2 { background: linear-gradient(135deg, #fd79a8, #e84393); }
.banner-content { position: relative; z-index: 2; }
.banner-tag { display: inline-block; background: rgba(255,255,255,0.25); color: #fff; font-size: 20rpx; padding: 6rpx 20rpx; border-radius: 20rpx; margin-bottom: 16rpx; backdrop-filter: blur(4px); }
.banner-title { display: block; font-size: 44rpx; font-weight: 800; color: #fff; margin-bottom: 8rpx; }
.banner-subtitle { display: block; font-size: 26rpx; color: rgba(255,255,255,0.85); margin-bottom: 24rpx; }
.banner-btn { display: inline-block; background: rgba(255,255,255,0.95); color: #6C5CE7; font-size: 24rpx; font-weight: 600; padding: 12rpx 32rpx; border-radius: 32rpx; }
.banner-deco { position: absolute; right: -20rpx; bottom: -20rpx; width: 240rpx; height: 240rpx; background: rgba(255,255,255,0.1); border-radius: 50%; }
.swiper-dots { display: flex; justify-content: center; margin-top: 20rpx; gap: 12rpx; }
.dot { width: 12rpx; height: 12rpx; border-radius: 6rpx; background: #ddd; transition: all 0.3s; }
.dot-active { width: 36rpx; background: #6C5CE7; }

/* ===== 保障横幅 ===== */
.trust-bar {
  display: flex; justify-content: space-around; padding: 20rpx 16rpx;
  background: #fff; border-radius: var(--radius); margin: 0 32rpx 24rpx;
  box-shadow: var(--shadow);
}
.trust-item { display: flex; align-items: center; gap: 8rpx; font-size: 22rpx; color: var(--text-secondary); font-weight: 500; }
.trust-icon { font-size: 28rpx; }

/* ===== 分类网格 ===== */
.section { margin-bottom: 32rpx; }
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.section-title { font-size: 34rpx; font-weight: 700; color: var(--text-primary); }
.section-more { font-size: 26rpx; color: var(--primary); font-weight: 500; }
.cate-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24rpx; }
.cate-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.cate-icon-wrap { width: 104rpx; height: 104rpx; border-radius: 28rpx; display: flex; align-items: center; justify-content: center; transition: transform 0.2s; }
.cate-item:active .cate-icon-wrap { transform: scale(0.92); }
.cate-icon { font-size: 48rpx; }
.cate-name { font-size: 24rpx; color: var(--text-secondary); font-weight: 500; }

/* ===== 商品网格 ===== */
.product-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20rpx; }
.product-card { border-radius: var(--radius); overflow: hidden; animation: fadeIn 0.4s ease-out both; transition: transform 0.2s; }
.product-card:active { transform: scale(0.97); }
.product-img-wrap { position: relative; height: 280rpx; overflow: hidden; }
.product-img { width: 100%; height: 100%; display: block; }
.product-tag { position: absolute; top: 16rpx; left: 16rpx; background: rgba(108,92,231,0.9); color: #fff; font-size: 20rpx; padding: 6rpx 16rpx; border-radius: 12rpx; backdrop-filter: blur(4px); }
.product-info { padding: 20rpx; }
.product-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 12rpx; display: block; }
.product-price-row { display: flex; align-items: baseline; gap: 12rpx; margin-bottom: 12rpx; }
.product-price { font-size: 34rpx; font-weight: 800; color: #e17055; }
.product-original { font-size: 22rpx; color: var(--text-hint); text-decoration: line-through; }
.product-meta { display: flex; align-items: center; justify-content: space-between; }
.product-seller { font-size: 22rpx; color: var(--text-hint); }
.product-views { font-size: 20rpx; color: var(--text-hint); }

/* ===== 最新上架列表 ===== */
.new-list { display: flex; flex-direction: column; gap: 20rpx; }
.new-item { display: flex; padding: 20rpx; gap: 24rpx; transition: transform 0.2s; }
.new-item:active { transform: scale(0.98); }
.new-item-img { width: 200rpx; height: 200rpx; border-radius: var(--radius-sm); flex-shrink: 0; display: block; }
.new-item-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
.new-item-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); display: block; }
.new-item-desc { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; display: block; }
.new-item-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 12rpx; }
.new-item-price { font-size: 32rpx; font-weight: 800; color: #e17055; }

/* ===== 底部 ===== */
.footer-text { text-align: center; padding: 40rpx 0 60rpx; font-size: 24rpx; color: var(--text-hint); }

/* ===== 回到顶部 ===== */
.back-top {
  position: fixed; right: 32rpx; bottom: 200rpx; width: 80rpx; height: 80rpx;
  background: #fff; border-radius: 50%; box-shadow: var(--shadow-lg);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transform: translateY(20rpx); transition: all 0.3s; pointer-events: none;
  font-size: 32rpx; color: var(--primary); font-weight: 700;
  z-index: 99;
}
.back-top.show { opacity: 1; transform: translateY(0); pointer-events: auto; }

.container { padding: 0 32rpx; }

/* SVG Icon sizes */
.logo-icon{width:40rpx;height:40rpx}
.nav-bell{width:40rpx;height:40rpx}
.search-icon{width:32rpx;height:32rpx;margin-right:16rpx}
.trust-icon{width:32rpx;height:32rpx}
.section-icon{width:36rpx;height:36rpx;margin-right:8rpx}
.section-title-wrap{display:flex;align-items:center}